<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!--
            Module install hone pe ek placeholder secret key store karo.
            Real key jwt.utils.get_or_create_secret_key() se generate hogi
            pehli API call pe automatically.

            noupdate="1" = upgrade pe overwrite nahi hoga
        -->
        <record id="jwt_secret_key_param" model="ir.config_parameter">
            <field name="key">jwt_rest_api.secret_key</field>
            <field name="value">PLACEHOLDER_WILL_BE_REPLACED_ON_FIRST_API_CALL</field>
        </record>
    </data>
</odoo>
